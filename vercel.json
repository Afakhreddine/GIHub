{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "fluid": true,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/debug.js":           { "maxDuration": 10 },
    "api/cron-guidelines.js": { "maxDuration": 120 },
    "api/cron-articles.js":   { "maxDuration": 60 },
    "api/cron-news.js":       { "maxDuration": 120 }
  },
  "crons": [
    { "path": "/api/cron-guidelines", "schedule": "0 6 * * 0" },
    { "path": "/api/cron-articles",   "schedule": "0 8 * * 0" },
    { "path": "/api/cron-news",       "schedule": "0 10 * * 0" }
  ],
  "rewrites": [
    { "source": "/api/debug",          "destination": "/api/debug" },
    { "source": "/api/claude",          "destination": "/api/claude" },
    { "source": "/api/cron-guidelines", "destination": "/api/cron-guidelines" },
    { "source": "/api/cron-articles",   "destination": "/api/cron-articles" },
    { "source": "/api/cron-news",       "destination": "/api/cron-news" },
    { "source": "/(.*)",                "destination": "/index.html" }
  ]
}
